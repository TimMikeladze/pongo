# ===========================================
# Database Configuration
# ===========================================

# Database driver: "sqlite" or "pg" (auto-detected from DATABASE_URL if not set)
# DB_DRIVER=sqlite

# PostgreSQL connection string
# DATABASE_URL=postgres://user:password@localhost:5432/pongo

# SQLite/Turso connection (default: file:./pongo/pongo.db)
# DATABASE_URL=file:./pongo/pongo.db
# DATABASE_URL=libsql://your-db.turso.io

# Turso auth token (required for remote libsql)
# TURSO_AUTH_TOKEN=

# ===========================================
# Authentication
# ===========================================

# Access code for dashboard login (leave empty for no auth)
# ACCESS_CODE=your-secret-code

# Session expiry in days (default: 7)
# EXPIRY_DAYS=7

# ===========================================
# Scheduler Configuration
# ===========================================

# Region identifier for this scheduler instance
# PONGO_REGION=us-east

# Max concurrent monitor checks (default: 10)
# SCHEDULER_MAX_CONCURRENCY=10

# Max retries for failed checks (default: 3)
# SCHEDULER_MAX_RETRIES=3

# Delay between retries in ms (default: 5000)
# SCHEDULER_RETRY_DELAY_MS=5000

# Scheduler server port (default: 3001)
# SCHEDULER_PORT=3001

# Scheduler URL for manual runs from dashboard
# SCHEDULER_URL=http://localhost:3001

# Enable manual run button in dashboard
# ENABLE_MANUAL_RUN=true

# ===========================================
# Cron API (for serverless/Vercel deployments)
# ===========================================

# Secret for authenticating cron requests from Vercel Cron or other schedulers
# Generate a secure random secret with: openssl rand -base64 32
# CRON_SECRET=your-cron-secret

# ===========================================
# Archiver Configuration
# ===========================================

# Enable archival of old check results
# ARCHIVAL_ENABLED=true

# Days to keep check results before archiving (default: 30)
# ARCHIVAL_RETENTION_DAYS=30

# Cron schedule for archival (default: 3am daily)
# ARCHIVAL_CRON=0 3 * * *

# Batch size for archival operations (default: 10000)
# ARCHIVAL_BATCH_SIZE=10000

# Local path for archives (default: ./archives)
# ARCHIVAL_LOCAL_PATH=./archives

# Archiver server port (default: 3002)
# ARCHIVER_PORT=3002

# S3 storage for archives (optional)
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=pongo/archives

# ===========================================
# Frontend Configuration
# ===========================================

# Public URL for metadata/SEO
# NEXT_PUBLIC_URL=https://pongo.sh

# Custom site name (used in metadata, page titles, footer)
# NEXT_PUBLIC_SITE_NAME=My Monitoring

# Hide the GitHub icon in the footer
# NEXT_PUBLIC_HIDE_GITHUB=false

# Hide the docs link in the appbar
# NEXT_PUBLIC_HIDE_DOCS=false

# Hide the support icon in the footer
# NEXT_PUBLIC_HIDE_SUPPORT=false

# Custom footer branding
# NEXT_PUBLIC_FOOTER_LOGO=/custom-logo.png
# NEXT_PUBLIC_FOOTER_TITLE=My Status
# NEXT_PUBLIC_FOOTER_CAPTION=service health dashboard

# Show about section on homepage
# SHOW_ABOUT=true
