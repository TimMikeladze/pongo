    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.11.1",
    "input-otp": "^1.4.2",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.1",
    "motion": "^12.23.26",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.6",
    "p-limit": "^7.2.0",
    "parquetjs-lite": "^0.8.7",
    "postgres": "^3.4.7",
