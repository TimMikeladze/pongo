{
  "name": "pongo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && if [[ \"$DATABASE_URL\" == sqlite* ]]; then bun run db:sqlite:migrate; else bun run db:pg:migrate; fi",
    "start": "next start",
    "lint": "bun biome check . && bun biome format .",
    "lint:fix": "bun biome check --unsafe --write . && bun biome format --write .",
    "lint:errors": "bun biome check --diagnostic-level error --unsafe .",
    "check": "if [ \"$CI\" = \"true\" ]; then bun run lint && bun run tsc && bun run test; else bun run lint:fix && bun run tsc && bun run test; fi",
    "prepare": "simple-git-hooks",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:pg:generate": "drizzle-kit generate --config=drizzle.config.pg.ts",
    "db:pg:migrate": "drizzle-kit migrate --config=drizzle.config.pg.ts",
    "db:pg:push": "drizzle-kit push --config=drizzle.config.pg.ts",
    "db:pg:studio": "drizzle-kit studio --config=drizzle.config.pg.ts",
    "db:sqlite:generate": "drizzle-kit generate --config=drizzle.config.sqlite.ts",
    "db:sqlite:migrate": "drizzle-kit migrate --config=drizzle.config.sqlite.ts",
    "db:sqlite:push": "drizzle-kit push --config=drizzle.config.sqlite.ts",
    "db:sqlite:studio": "drizzle-kit studio --config=drizzle.config.sqlite.ts",
    "scheduler": "bun run src/scheduler/index.ts",
    "archiver": "bun run src/archiver/index.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run check && git add ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@hono/node-server": "^1.19.7",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.15.15",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
